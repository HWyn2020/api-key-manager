{
  "name": "api-key-manager",
  "version": "1.0.0",
  "description": "Secure API key manager with rotation, expiration, and rate limiting",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:migrate": "tsx src/database/migrate.ts"
  },
  "keywords": [
    "api-key",
    "security",
    "rate-limit",
    "rotation"
  ],
  "author": "Gumball & Claude Code",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.0",
    "better-sqlite3": "^11.0.0",
    "express": "^4.18.0",
    "ioredis": "^5.3.0",
    "jose": "^5.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
